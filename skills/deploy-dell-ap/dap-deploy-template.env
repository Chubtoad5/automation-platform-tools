# =============================================================================
# dap-deploy-template.env — fill this in before a deploy-dell-ap run.
#
# One place to capture every intake answer (see intake.md). Copy it, fill the
# blanks, and have it on hand when the skill interviews you. The agent still
# confirms a plan before running anything.
#
# !! NEVER commit real secrets. Put a secret *reference* (name/path) here, or
#    leave the value blank and supply it at run time. This file is a worksheet,
#    not a credential store.
# =============================================================================

# --- 1. Topology -------------------------------------------------------------
TOPOLOGY=                      # single-node | multi-node
NODE_COUNT=                    # multi-node: total nodes (3 recommended minimum)

# --- 2. Target host(s) -------------------------------------------------------
# Multi-node: list all nodes; the FIRST is where you run install rke2 / ap-bundle.
NODES=                         # e.g. "10.0.0.11 10.0.0.12 10.0.0.13"
SSH_USER=                      # e.g. ubuntu
SSH_AUTH=                      # key | password
SSH_KEY_PATH=                  # if key:  /path/to/id_ed25519
# if password: supply at run time. Confirm `sshpass` is installed on THIS machine.

# --- 3. Base domain + DNS ----------------------------------------------------
BASE_DOMAIN=                   # e.g. example.lab
CLUSTER_NAME=                  # multi-node only: the -tls-san / API name (resolves to NODE IPs)
LB_IP=                         # multi-node only: dedicated ingress VIP (free L2 IP, NOT a node IP)
# Required DNS (point portal/orchestrator/mtls-* at LB_IP on multi-node, at the host IP on single):
#   portal.<HOST_FQDN>  orchestrator.<HOST_FQDN>  mtls-orchestrator.<HOST_FQDN>  mtls-recovery-orchestrator.<HOST_FQDN>
# Multi-node: HOST_FQDN = CLUSTER_NAME (set it on `install ap-bundle`).
HOST_FQDN=                     # single: usually unset (defaults to <hostname>.<BASE_DOMAIN>); multi: = CLUSTER_NAME

# --- 4. Container registry ---------------------------------------------------
REGISTRY_MODE=                 # harbor (ap-tools installs it) | external
REGISTRY_HOSTPORT=             # external: host:port  (no https://)
REGISTRY_USER=                 # external: username
REGISTRY_PASS=                 # supply at run time
REGISTRY_HAS_RKE2_IMAGES=      # true -> pass -registry to `install rke2`
SKIP_IMAGES_LOADER=false       # true if the DAP images are ALREADY in the registry

# --- 4b. DAP version + bundle ------------------------------------------------
AP_BUNDLE_URL=                 # blank = default pinned version; else the bundle URL, or a pre-staged .zip filename
DOWNLOAD_AP_BUNDLE=false        # true to fetch the (~19 GB) bundle during install

# --- 5. Identity / organization ----------------------------------------------
ORG_NAME=
ORG_DESC=
FIRST_NAME=
LAST_NAME=
USERNAME=
EMAIL=

# --- 6. Resources (confirm before running) -----------------------------------
# single-node: 16 vCPU / 34 GB / 500 GB+   multi-node: 16 vCPU / 20 GB+ per node / 500 GB+
OS=                            # ubuntu | debian | rhel | rocky | almalinux | sles | ...

# --- 7. NTP ------------------------------------------------------------------
NTP_SERVERS=                   # space/comma-separated; blank = OS default (confirm hosts are time-synced)

# --- 8. Mode -----------------------------------------------------------------
MODE=                          # online | air-gapped

# --- 9. Optional add-ons (post-install; only if asked) -----------------------
ADDONS=                        # any of: swfs velero monitoring   (blank = none)
# Velero (install velero): S3 endpoint + creds (a SeaweedFS bucket is the intended backend).
VELERO_S3_URL=                 # e.g. https://s3.metrics.example:8333
VELERO_S3_ACCESS_KEY=          # supply at run time
VELERO_S3_SECRET_KEY=          # supply at run time
VELERO_BUCKET=                 # multi-cluster: = cluster id (match CLUSTER_NAME). Blank = default 'velero' (single-cluster only).
                               #   Pre-create the per-cluster buckets on SeaweedFS via EXTRA_BUCKETS (below).
EXTRA_BUCKETS=                 # on swfs install: space-separated extra buckets to pre-create, e.g. "dev-demo-01 dev-test-03"
# Monitoring (install monitoring): shared observability host + per-cluster label.
MONITORING_HOST=               # FQDN/IP of the SeaweedFS monitoring host (Loki/Grafana/Prometheus)
# CLUSTER_NAME (section 3) doubles as the metrics/logs label here and as the Velero bucket id.
